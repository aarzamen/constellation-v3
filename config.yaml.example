# Constellation Configuration
# Created automatically on first run. Gitignored.

# Data source
source:
  path: ""  # Set during first-run setup
  provider: "claude"

# Embedding
embedding:
  model: "all-MiniLM-L6-v2"

# Server
server:
  port: 8420
  host: "127.0.0.1"

# Visualization defaults
display:
  auto_rotate: true
  colorblind_mode: false
  layout: "3d-force"  # "3d-force", "2d-flat", "by-cluster", "temporal-helix"

# Additional data sources (optional)
# sources:
#   chatgpt:
#     path: /path/to/chatgpt/conversations.json
#   gemini:
#     path: /path/to/gemini/ai-studio/folder
#   grok:
#     path: /path/to/grok/export.json

# MCP server
mcp:
  enabled: true
